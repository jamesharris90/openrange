# Local development overrides — copy to .env.local (git-ignored).
#
# Point the local Vite dev server at the Railway production backend
# instead of the local Express server. Useful when you need to read
# data that was ingested directly into the production DB.
#
# Also set EXTRA_ALLOWED_ORIGINS on Railway to permit this origin:
#   EXTRA_ALLOWED_ORIGINS=http://localhost:5173
#
# Uncomment the line below to enable:
# VITE_API_BASE_URL=https://openrange-backend-production.up.railway.app
